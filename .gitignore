# ============================================================
# COBILL — .gitignore
# ============================================================

# ------------------------------------------------------------
# PROJECT-SPECIFIC EXCLUSIONS
# ------------------------------------------------------------
session-handoff.md
Idée.md
consignes holberton.md

# Compiled COBOL binaries
bin/*
!bin/.gitkeep

# ISAM data files (contain user data)
data/*
!data/.gitkeep

# Generated PDFs and PostScript output
pdf/*
!pdf/.gitkeep

# ------------------------------------------------------------
# COBOL / GnuCOBOL
# ------------------------------------------------------------
*.o
*.so
*.dylib
*.dll
*.exe
*.int
*.idy
*.gnt
*.lst
*.cbl.lst
*.cob.lst

# ------------------------------------------------------------
# PostScript / Ghostscript
# ------------------------------------------------------------
*.ps.bak
*.pdf.tmp

# ------------------------------------------------------------
# Python (build scripts, venv, bytecode)
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
venv/
.venv/
env/
.env/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
*.egg
dist/
build/
*.whl

# ------------------------------------------------------------
# macOS
# ------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?

# Finder
.fseventsd
.TemporaryItems

# Volumes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# ------------------------------------------------------------
# Linux
# ------------------------------------------------------------
*~
.nfs*

# ------------------------------------------------------------
# Windows
# ------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.stackdump
[Dd]esktop.ini

# ------------------------------------------------------------
# Editors & IDEs
# ------------------------------------------------------------

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# JetBrains (IntelliJ, CLion, etc.)
.idea/
*.iml
*.iws
*.ipr
out/
cmake-build-*/

# Vim / Neovim
*.swp
*.swo
*.swn
*~
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
Session.vim
Sessionx.vim
.netrwhist
tags

# Emacs
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*
*_flymake.*
/server/
.projectile
.dir-locals.el
.flycheck_*

# Sublime Text
*.sublime-workspace
*.sublime-project

# TextMate
*.tmproj
*.tmproject
tmtags

# ------------------------------------------------------------
# Build & Package Managers
# ------------------------------------------------------------
node_modules/
bower_components/
jspm_packages/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock

# ------------------------------------------------------------
# Apache / Server
# ------------------------------------------------------------
*.pid
*.seed
*.pid.lock
error_log
access_log

# ------------------------------------------------------------
# Environment & Secrets
# ------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
credentials.json
secrets.yaml
secrets.yml

# ------------------------------------------------------------
# Archives & Compressed
# ------------------------------------------------------------
*.tar
*.tar.gz
*.tgz
*.tar.bz2
*.zip
*.rar
*.7z

# ------------------------------------------------------------
# Misc
# ------------------------------------------------------------
*.bak
*.tmp
*.temp
*.orig
*.rej
*.patch
*.diff
core
core.*
*.core
.cache/
.parcel-cache/
.sass-cache/
*.css.map
*.js.map


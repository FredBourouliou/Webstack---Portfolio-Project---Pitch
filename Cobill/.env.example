# Copy this to `.env` and fill in. The .env file is gitignored.

# Production server
LECOBOL_PROD_HOST=                 # e.g. 1.2.3.4 or hostname
LECOBOL_PROD_USER=ubuntu
LECOBOL_PROD_SSH_KEY=~/.ssh/lecobol-deploy.pem
LECOBOL_PROD_SSH_HOST_ALIAS=lecobol-prod

# AWS metadata
LECOBOL_AWS_ACCOUNT=
LECOBOL_AWS_REGION=eu-west-3
LECOBOL_AWS_INSTANCE_ID=
LECOBOL_AWS_SECURITY_GROUP=
LECOBOL_AWS_KEYPAIR_NAME=lecobol-deploy

# Auth. Production uses COBILL_AUTH_HASH (sha512crypt).
# COBILL_AUTH_PASS is a dev/fallback in plaintext. Hash wins if both set.
# Generate a hash: scripts/gen-auth-hash.sh
COBILL_AUTH_USER=admin
COBILL_AUTH_HASH=
COBILL_AUTH_PASS=

# Domain
LECOBOL_DOMAIN=lecobol.com
LECOBOL_PUBLIC_URL=
